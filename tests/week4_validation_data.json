  "expected_indicators": {
    "description": "预期的财务指标计算结果（用于验证系统计算准确性）",
    "calculation_formulas": {
      "roe": "净利润 / 平均所有者权益 * 100%",
      "roa": "净利润 / 平均总资产 * 100%",
      "asset_liability_ratio": "总负债 / 总资产 * 100%",
      "gross_profit_margin": "(营业收入 - 营业成本) / 营业收入 * 100%",
      "current_ratio": "流动资产 / 流动负债",
      "free_cash_flow": "经营现金流 - 资本支出"
    },
    
    "2024": {
      "roe": {
        "formula": "807.23 / ((1870.22 + 2005.25) / 2) * 100%",
