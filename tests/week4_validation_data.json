  "data_quality_checks": {
    "description": "数据质量验证规则",
    
    "completeness": {
      "required_fields": [
        "stock_code",
        "report_date",
        "total_assets",
        "total_liabilities",
        "owners_equity",
        "total_revenue",
        "net_profit"
      ],
      "allow_null_fields": [
        "accounts_receivable",
        "long_term_investments"
      ]
    },
    
    "accuracy": {
      "rules": [
        {
          "field": "total_assets",
          "condition": "> 0",
          "error_message": "总资产必须大于0"
        },
        {
          "field": "owners_equity",
          "condition": "total_assets == total_liabilities + owners_equity",
          "tolerance": 0.01,
          "error_message": "会计恒等式不成立"
        },
        {
